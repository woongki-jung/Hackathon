# 관리자 초기 계정
ADMIN_USERNAME=           # 초기 관리자 아이디 (4~20자, 영소문자/숫자/_)
ADMIN_PASSWORD=           # 초기 관리자 비밀번호 (8자 이상, 영문+숫자+특수문자)

# 세션
SESSION_SECRET=           # 세션 암호화 키 (32자 이상 무작위 문자열)

# SQLite 데이터베이스
DATABASE_PATH=./data/app.db

# 메일 서버 접속 정보 (IMAP)
MAIL_IMAP_HOST=           # IMAP 서버 주소 (예: imap.gmail.com)
MAIL_IMAP_PORT=993        # IMAP 포트 (SSL: 993, 비SSL: 143)
MAIL_USERNAME=            # 메일 계정 아이디 (예: user@example.com)
MAIL_PASSWORD=            # 메일 계정 비밀번호
MAIL_USE_SSL=true         # SSL/TLS 사용 여부 (true | false)

# Gemini API 설정
GEMINI_API_KEY=           # Google AI Studio API 키 (https://aistudio.google.com)
GEMINI_MODEL=gemini-2.0-flash

# 백그라운드 작업 설정
MAIL_CHECK_INTERVAL=3600000   # 메일 확인 주기 (ms 단위, 기본 1시간)

# 데이터 저장 경로
MAIL_STORAGE_PATH=./data/mails
GLOSSARY_STORAGE_PATH=./data/terms

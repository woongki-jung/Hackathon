# 관리자 초기 계정
ADMIN_USERNAME=           # 초기 관리자 아이디 (4~20자, 영소문자/숫자/_)
ADMIN_PASSWORD=           # 초기 관리자 비밀번호 (8자 이상, 영문+숫자+특수문자)

# 세션
SESSION_SECRET=           # 세션 암호화 키 (32자 이상 무작위 문자열)

# PostgreSQL 데이터베이스 (Vercel Postgres / Neon)
# Vercel 대시보드 → Storage → Neon Postgres 연결 후 자동 생성되는 값을 사용
POSTGRES_URL=             # 풀링 연결 URL (일반 쿼리용)
POSTGRES_URL_NON_POOLING= # 비풀링 연결 URL (Drizzle 마이그레이션용)

# Gemini API 설정
GEMINI_API_KEY=           # Google AI Studio API 키 (https://aistudio.google.com)
GEMINI_MODEL=gemini-2.0-flash

# 웹훅 설정
# 외부 시스템(메일 포워더 등)에서 POST /api/webhook/{code} 로 메일 데이터를 전송
# 웹훅 코드(code)는 대시보드 → 환경설정에서 생성
